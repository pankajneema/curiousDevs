# ─── Database ────────────────────────────────────────────────
# Neon (recommended) → neon.tech → New Project → copy Connection String
# Supabase alternative → supabase.com → Project Settings → Database → Connection String (URI mode)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── Resend (email) ──────────────────────────────────────────
# resend.com → API Keys → Create API Key
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─── Team inbox ──────────────────────────────────────────────
# Email address that receives contact form submissions + new subscriber alerts
CONTACT_EMAIL="hello@curiousdevs.com"
